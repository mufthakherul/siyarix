# .graphifyignore
# Exclude folders and files from being scanned/ingested by Graphify.
# Syntactically identical to a standard .gitignore.

# --- Dependencies & Build Output ---
node_modules/
dist/
build/
develop-eggs/
eggs/
.eggs/
lib/
lib64/
parts/
sdist/
var/
wheels/
pip-wheel-metadata/
share/python-wheels/
*.egg-info/
*.egg
MANIFEST
target/
Cargo.lock

# --- Virtual Environments ---
.venv/
venv/
env/

# --- Testing, Coverage & Cache ---
__pycache__/
*.py[cod]
*$py.class
*.so
.Python
.pytest_cache/
.coverage
.coverage.*
htmlcov/
.mypy_cache/
.pyre/
.ruff_cache/

# --- Generated Code ---
*.generated.py

