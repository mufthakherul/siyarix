# ── Phalanx Environment Configuration ─────────────────────────────────
# Copy this file to .env and adjust for your environment.

## General Settings
PHALANX_HOME=~/.phalanx
PHALANX_CONFIG=~/.phalanx/config.yaml
PHALANX_DEBUG=0
PHALANX_LOG_LEVEL=INFO
PHALANX_PERSONA=bug_hunter
PHALANX_PROVIDER=openai
PHALANX_TIMEOUT=300
PHALANX_SAFE_MODE=0
PHALANX_NO_TELEMETRY=0

## Provider API Keys
OPENAI_API_KEY=sk-...
GEMINI_API_KEY=...
GROQ_API_KEY=gsk_...
TOGETHER_API_KEY=...

## Threat Intelligence (STIX/TAXII)
TAXII_URL=https://...
TAXII_USERNAME=
TAXII_PASSWORD=
MISP_URL=https://...
MISP_API_KEY=

## SIEM Forwarding
PHALANX_SPLUNK_URL=https://splunk.company.com:8088/services/collector/event
PHALANX_SPLUNK_TOKEN=
PHALANX_ELASTIC_URL=https://elastic.company.com:9200
PHALANX_ELASTIC_KEY=

## Redis (Distributed Mode)
REDIS_URL=redis://localhost:6379

## OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=phalanx

## Distributed Worker
PHALANX_WORKER_ID=
PHALANX_WORKER_CAPABILITIES=

## Dashboard
PHALANX_DASHBOARD_PORT=8090
PHALANX_DASHBOARD_HOST=0.0.0.0
