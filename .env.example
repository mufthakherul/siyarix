# ── Siyarix Environment Configuration ─────────────────────────────────
# Copy this file to .env and adjust for your environment.
#   cp .env.example .env && $EDITOR .env

## General Settings
SIYARIX_HOME=~/.siyarix
SIYARIX_CONFIG=~/.siyarix/settings.toml
SIYARIX_DEBUG=0
SIYARIX_LOG_LEVEL=INFO
SIYARIX_MODE=cli
SIYARIX_PERSONA=bug_hunter
SIYARIX_PROVIDER=noop
SIYARIX_TIMEOUT=300
SIYARIX_SAFE_MODE=0
SIYARIX_NO_TELEMETRY=0
SIYARIX_STEALTH=0
SIYARIX_MAX_TOKENS=100000
SIYARIX_MAX_COST_USD=2.00
SIYARIX_DRY_RUN=0

## AI Provider API Keys
# Replace the placeholders below with your actual API keys.
# Never commit real API keys to version control.
OPENAI_API_KEY=sk-placeholder-replace-me
ANTHROPIC_API_KEY=sk-ant-placeholder-replace-me
GEMINI_API_KEY=your-gemini-key-here
GROQ_API_KEY=gsk-placeholder-replace-me
MISTRAL_API_KEY=your-mistral-key-here
DEEPSEEK_API_KEY=your-deepseek-key-here
TOGETHER_API_KEY=your-together-key-here
OPENROUTER_API_KEY=your-openrouter-key-here
PERPLEXITY_API_KEY=your-perplexity-key-here
AZURE_OPENAI_KEY=your-azure-key-here
AZURE_OPENAI_ENDPOINT=https://your-resource.openai.azure.com

## Redis (for worker/dashboard mode)
REDIS_URL=redis://localhost:6379
REDIS_PORT=6379

## Threat Intelligence (STIX/TAXII)
TAXII_URL=https://...
TAXII_USERNAME=
TAXII_PASSWORD=
TAXII_COLLECTION=
MISP_URL=https://...
MISP_API_KEY=

## SIEM Forwarding
SIYARIX_SPLUNK_URL=https://splunk.company.com:8088/services/collector/event
SIYARIX_SPLUNK_TOKEN=
SIYARIX_ELASTIC_URL=https://elastic.company.com:9200
SIYARIX_ELASTIC_KEY=
SIYARIX_ELASTIC_VERIFY_SSL=1

## OpenTelemetry
OTEL_EXPORTER_OTLP_ENDPOINT=http://localhost:4318
OTEL_SERVICE_NAME=siyarix
OTEL_EXPORTER_OTLP_PROTOCOL=http/protobuf

## Dashboard
SIYARIX_DASHBOARD_PORT=8090
SIYARIX_DASHBOARD_HOST=0.0.0.0

## Remote Orchestrator (communicator mode)
SIYARIX_ORCHESTRATOR_URL=
SIYARIX_ORCHESTRATOR_TOKEN=

## Notifications
SIYARIX_SLACK_WEBHOOK_URL=
SIYARIX_DISCORD_WEBHOOK_URL=
SIYARIX_TEAMS_WEBHOOK_URL=
SIYARIX_SMTP_SERVER=
SIYARIX_SMTP_PORT=587
SIYARIX_SMTP_USERNAME=
SIYARIX_SMTP_PASSWORD=
SIYARIX_NOTIFICATION_EMAIL=
