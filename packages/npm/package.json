{
  "name": "@mufthakherul/siyarix-agent",
  "version": "0.1.0",
  "description": "Official npm launcher for Siyarix Agent CLI (Python-powered)",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/mufthakherul/Siyarix.git",
    "directory": "cli/agent/npm"
  },
  "homepage": "https://github.com/mufthakherul/Siyarix/tree/main/cli/agent/npm",
  "bugs": {
    "url": "https://github.com/mufthakherul/Siyarix/issues"
  },
  "keywords": [
    "siyarix",
    "security",
    "cybersecurity",
    "cli",
    "agent",
    "npm"
  ],
  "type": "commonjs",
  "bin": {
    "siyarix-agent": "bin/siyarix-agent.js",
    "siyarix": "bin/siyarix-agent.js",
    "siyarix-agent-install": "bin/siyarix-agent-install.js"
  },
  "scripts": {
    "test": "node --check bin/siyarix-agent.js && node --check bin/siyarix-agent-install.js && node --check lib/installer.js",
    "pack:check": "npm pack --dry-run"
  },
  "engines": {
    "node": ">=20"
  },
  "files": [
    "bin",
    "lib",
    "README.md"
  ],
  "publishConfig": {
    "registry": "https://npm.pkg.github.com",
    "access": "public"
  }
}
